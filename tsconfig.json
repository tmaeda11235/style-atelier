{
  "extends": "plasmo/templates/tsconfig.base",
  "exclude": [
    "node_modules",
    "vitest.config.ts",
    "vitest.setup.ts",
    "playwright.config.ts"
  ],
  "include": [
    ".plasmo/index.d.ts",
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "./tests/**/*.ts",
    "./tests/**/*.tsx"
  ],
  "compilerOptions": {
    "paths": {
      "~*": ["./src/*"],
      "@/*": ["./src/*"]
    },
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "types": [
      "chrome",
      "google.accounts",
      "@webgpu/types",
      "node",
      "@testing-library/jest-dom"
    ]
  }
}
