    "postcss": "^8.5.6",
    "prettier": "3.8.4",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8",
    "vitest-canvas-mock": "^1.1.4"
  },
  "manifest": {
    "name": "__MSG_extName__",
    "description": "__MSG_extDescription__",
    "default_locale": "ja",
    "key": "",
    "permissions": [
      "activeTab",
      "identity",
      "storage",
      "offscreen"
    ],
    "host_permissions": [
      "https://midjourney.com/*",
      "https://*.midjourney.com/*",
      "https://*.discord.com/*",
      "https://*.discordapp.com/*",
      "https://*.discordapp.net/*"
    ],
    "content_security_policy": {
      "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
    },
    "web_accessible_resources": [
      {
        "resources": [
          "assets/wasm/*"
        ],
        "matches": [
          "<all_urls>"
        ]
      }
    ],
    "oauth2": {
      "client_id": "81426269486-2pi6vl3bqhdr6l9tn1pddv6vh2mu3u0t.apps.googleusercontent.com",
      "scopes": [
        "https://www.googleapis.com/auth/drive.file"
      ]
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  },
  "msw": {
    "workerDirectory": [
      "assets"
    ]
  }
}
