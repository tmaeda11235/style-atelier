{
  "name": "ml-style-atelier",
  "displayName": "__MSG_extName__",
  "version": "0.2.0",
  "description": "__MSG_extDescription__",
  "author": "tmaeda11235@gmail.com",
  "alias": {
    "jiti": false,
    "@tailwindcss/oxide": false
  },
  "scripts": {
    "dev": "plasmo dev",
    "dev:cached": "cross-env PLASMO_PUBLIC_USE_LOCAL_CACHE=true plasmo dev",
    "serve:cache": "node scripts/serve-cache.mjs",
    "build": "plasmo build",
    "package": "plasmo package",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "lint": "eslint src/ && node scripts/check-i18n-keys.mjs",
    "prepare": "husky",
    "test:mutate": "stryker run",
    "push": "npm run lint && node scripts/smart-pre-push.mjs && git commit -am \"chore: update test proof for CI verification\" && git push origin HEAD --no-verify",
    "postinstall": "patch-package && node scripts/setup-env.mjs",
    "preinstall": "node -e \"const v=process.versions.node.split('.').map(Number); if(v[0]<20 || (v[0]===20 && v[1]<12)) { console.error('Error: Node.js version must be >= 20.12.0. Current version is ' + process.version); process.exit(1); }\""
  },
  "dependencies": {
    "@litert-lm/core": "^0.13.1",
    "@tanstack/query-async-storage-persister": "^5.101.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "browser-image-compression": "^2.0.2",
    "budoux": "^0.8.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.2.1",
    "dexie-react-hooks": "^4.2.0",
    "fflate": "^0.8.3",
    "flexsearch": "^0.8.212",
